{
  "pluginId": "com.digitalarsenal.flow.query-anchor",
  "name": "ISS Radius Query Builder",
  "version": "1.0.0",
  "pluginFamily": "analysis",
  "methods": [
    {
      "methodId": "build_radius_query",
      "displayName": "Build Radius Query",
      "inputPorts": [
        {
          "portId": "tick",
          "acceptedTypeSets": [
            {
              "setId": "timer-tick",
              "allowedTypes": [
                {
                  "schemaName": "TimerTick.fbs",
                  "fileIdentifier": "TICK"
                }
              ]
            }
          ],
          "minStreams": 1,
          "maxStreams": 1,
          "required": true
        }
      ],
      "outputPorts": [
        {
          "portId": "query",
          "acceptedTypeSets": [
            {
              "setId": "radius-query",
              "allowedTypes": [
                {
                  "schemaName": "AnchorRadiusQuery.fbs",
                  "fileIdentifier": "ARQY"
                }
              ]
            }
          ],
          "minStreams": 1,
          "maxStreams": 1,
          "required": true
        }
      ],
      "maxBatch": 1,
      "drainPolicy": "drain-until-yield"
    }
  ]
}
