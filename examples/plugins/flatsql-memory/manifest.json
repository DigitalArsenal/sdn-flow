{
  "pluginId": "com.digitalarsenal.flatsql.memory",
  "name": "FlatSQL In-Memory Store",
  "version": "1.0.0",
  "pluginFamily": "storage",
  "capabilities": [
    "storage_query"
  ],
  "externalInterfaces": [
    {
      "interfaceId": "memory-db",
      "kind": "database",
      "direction": "bidirectional",
      "capability": "storage_query",
      "resource": "memory://iss-proximity",
      "description": "Transient in-memory FlatSQL database used for OMM ingest and proximity queries."
    }
  ],
  "methods": [
    {
      "methodId": "upsert_omm_records",
      "displayName": "Upsert OMM Records",
      "inputPorts": [
        {
          "portId": "omms",
          "acceptedTypeSets": [
            {
              "setId": "omm",
              "allowedTypes": [
                {
                  "schemaName": "OMM.fbs",
                  "fileIdentifier": "OMM "
                }
              ]
            }
          ],
          "minStreams": 1,
          "maxStreams": 1,
          "required": true
        }
      ],
      "outputPorts": [
        {
          "portId": "records",
          "acceptedTypeSets": [
            {
              "setId": "catalog-record",
              "allowedTypes": [
                {
                  "schemaName": "CatalogRecord.fbs",
                  "fileIdentifier": "CTLG"
                }
              ]
            }
          ],
          "minStreams": 1,
          "maxStreams": 1,
          "required": true
        }
      ],
      "maxBatch": 1024,
      "drainPolicy": "drain-until-yield"
    },
    {
      "methodId": "query_objects_within_radius",
      "displayName": "Query Objects Within Radius",
      "inputPorts": [
        {
          "portId": "query",
          "acceptedTypeSets": [
            {
              "setId": "radius-query",
              "allowedTypes": [
                {
                  "schemaName": "AnchorRadiusQuery.fbs",
                  "fileIdentifier": "ARQY"
                }
              ]
            }
          ],
          "minStreams": 1,
          "maxStreams": 1,
          "required": true
        }
      ],
      "outputPorts": [
        {
          "portId": "matches",
          "acceptedTypeSets": [
            {
              "setId": "proximity-set",
              "allowedTypes": [
                {
                  "schemaName": "ProximitySelection.fbs",
                  "fileIdentifier": "PRXY"
                }
              ]
            }
          ],
          "minStreams": 1,
          "maxStreams": 1,
          "required": true
        }
      ],
      "maxBatch": 32,
      "drainPolicy": "drain-until-yield"
    }
  ]
}
