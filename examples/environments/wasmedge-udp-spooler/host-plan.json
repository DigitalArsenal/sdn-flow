      "execution": "compiled-wasm",
      "authority": "local",
      "adapter": "host-internal",
      "startupPhase": "session",
      "autoStart": true,
      "dependsOn": [],
      "requiredCapabilities": ["network", "filesystem"],
      "bindings": [
        {
          "bindingId": "udp-ingest-direct",
          "direction": "listen",
          "transport": "direct",
          "url": "udp://0.0.0.0:40123",
