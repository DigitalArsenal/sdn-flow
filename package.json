{
  "name": "sdn-flow",
  "version": "0.3.0",
  "description": "Isomorphic flow authoring, runtime, authorization, and deployment tooling for schema-driven WASM systems.",
  "type": "module",
  "bin": {
    "sdn-flow-host": "./bin/sdn-flow-host.js",
    "sdn-flow-editor": "./bin/sdn-flow-editor.js"
  },
  "exports": {
    ".": "./src/index.js",
    "./runtime": "./src/runtime/index.js",
    "./designer": "./src/designer/index.js",
    "./editor": "./src/editor/index.js",
    "./auth": "./src/auth/index.js",
    "./host": "./src/host/index.js",
    "./transport": "./src/transport/index.js",
    "./deploy": "./src/deploy/index.js",
    "./compiler": "./src/compiler/index.js",
    "./compliance": "./src/compliance/index.js",
    "./wrappers": "./src/wrappers/index.js",
    "./wrappers/browser": "./src/wrappers/browser.js",
    "./wrappers/bun": "./src/wrappers/bun.js",
    "./wrappers/deno": "./src/wrappers/deno.js",
    "./schemas/*": "./schemas/*"
  },
  "files": [
    "src/",
    "native/",
    "schemas/",
    "docs/",
    ".claude/",
    "tools/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build:shared-runtime-constants": "node scripts/build-shared-runtime-constants.mjs",
    "build:editor-assets": "node scripts/build-editor-assets.mjs",
    "build:editor-executable": "node scripts/editor-executable.mjs build",
    "build:runtime-abi": "node scripts/build-runtime-abi.mjs",
    "start": "node scripts/editor-executable.mjs start",
    "test": "npm run build:shared-runtime-constants && npm run check:plugin-compliance && node --test",
    "check:plugin-compliance": "node scripts/check-shared-module-compliance.mjs"
  },
  "keywords": [
    "flow",
    "wasm",
    "sdn",
    "space-data-network",
    "orchestration",
    "flatbuffers"
  ],
  "author": {
    "name": "DigitalArsenal.io, Inc.",
    "url": "https://digitalarsenal.io"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/DigitalArsenal/sdn-flow.git"
  },
  "homepage": "https://github.com/DigitalArsenal/sdn-flow",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "hd-wallet-wasm": "^2.0.1",
    "space-data-module-sdk": "git+https://github.com/DigitalArsenal/space-data-module-sdk.git#9bdcc12bb6aede0a6e7d7fd813ec3edbc56c1738"
  },
  "devDependencies": {
    "@node-red/editor-client": "^4.1.7",
    "@node-red/nodes": "^4.1.7",
    "deno": "^2.7.5",
    "flatbuffers": "^25.9.23",
    "flatsql": "^0.4.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
